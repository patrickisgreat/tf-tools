# Local .terraform directories
**/.terraform/*
.terraform.tfstate.lock.info

# State files (never commit state)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# tfvars may contain secrets — keep the *.example templates only
*.tfvars
*.tfvars.json
!*.tfvars.example

# Saved plans
*.tfplan
*.tfplan.*

# CLI config / credentials
.terraformrc
terraform.rc

# Override files (local-only convenience overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Editor / OS noise
.DS_Store
.idea/
.vscode/

# NOTE: .terraform.lock.hcl IS committed for root configs — do not ignore it.
